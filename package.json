{
  "name": "gesture-recognizer-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A clone of the MediaPipe Studio Gesture Recognizer demo built with TypeScript and Vite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:widget": "tsc --noEmit && vite build --config vite.widget.config.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
